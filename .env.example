# --- HTTP bind ------------------------------------------------------
# The Node process listens here; nginx (or whatever reverse proxy you
# put in front) terminates TLS and forwards to this port.
PORT=8080
HOST=127.0.0.1

# --- Database file --------------------------------------------------
# better-sqlite3 file path. systemd unit places this under
# /var/lib/wol-lobby/lobby.db on the Oracle VM; for local dev keep
# it under the repo so a wipe is just `rm`.
DB_PATH=./lobby.db

# Where uploaded replays land. R2's replacement is a plain folder.
# Make sure the systemd User= has read/write here.
REPLAYS_DIR=./replays

# --- Tunable knobs (mirror wrangler.toml [vars]) --------------------
MAX_CONCURRENT_USERS=60
MAX_ACTIVE_GAMES=8
CHAT_MSGS_PER_MIN=30
# Global chat (/global/ws). Separate from per-lobby chat so the shared
# channel can be throttled / bounded independently. Connections + history
# are the only global-chat memory cost — both capped here.
#   GLOBAL_CHAT_MSGS_PER_MIN   per-user send rate (anti-flood)
#   GLOBAL_CHAT_HISTORY        recent messages kept in RAM (sent to joiners)
#   GLOBAL_CHAT_MAX_CONNECTIONS room capacity; defaults to MAX_CONCURRENT_USERS
GLOBAL_CHAT_MSGS_PER_MIN=20
GLOBAL_CHAT_HISTORY=100
GLOBAL_CHAT_MAX_CONNECTIONS=60
# Anti-spam (slow mode + auto-timeout):
#   GLOBAL_CHAT_MIN_INTERVAL_MS  min gap between two messages (slow mode)
#   GLOBAL_CHAT_TIMEOUT_STRIKES  slow-mode/rate trips within a minute → auto-mute
#   GLOBAL_CHAT_TIMEOUT_MS       how long the auto-mute lasts
GLOBAL_CHAT_MIN_INTERVAL_MS=1500
GLOBAL_CHAT_TIMEOUT_STRIKES=5
GLOBAL_CHAT_TIMEOUT_MS=30000
DAILY_REQUEST_BUDGET=100000
DAILY_DEGRADE_THRESHOLD=80000
DAILY_HARD_LIMIT=95000
REPLAY_MAX_BYTES=5242880
LOBBY_MAX_PLAYERS=8
DEV_AUTH_BYPASS=false

# --- Public base URL ------------------------------------------------
# Used to build the Discord OAuth redirect_uri. MUST match exactly
# the entry registered in the Discord Developer Portal under
# OAuth2 → Redirects. Include the scheme and trailing-slash-less path.
#
# Example for the Oracle VM + DuckDNS deploy:
#   PUBLIC_BASE_URL=https://wol-lobby.duckdns.org
#
# For local dev with DEV_AUTH_BYPASS=true this can be left blank.
PUBLIC_BASE_URL=replace-me-with-https://your-domain

# --- Secrets --------------------------------------------------------
# Generate a fresh 32-byte random key for JWT_SIGNING_KEY:
#   openssl rand -hex 32
JWT_SIGNING_KEY=replace-me-with-openssl-rand-hex-32

# Discord OAuth credentials. Create the application here:
#   https://discord.com/developers/applications
# In the application's OAuth2 page:
#   * Copy the Client ID → DISCORD_CLIENT_ID
#   * Reset / view the Client Secret → DISCORD_CLIENT_SECRET
#   * Under "Redirects", add  ${PUBLIC_BASE_URL}/auth/login/callback
DISCORD_CLIENT_ID=replace-me-with-your-discord-app-client-id
DISCORD_CLIENT_SECRET=replace-me-with-your-discord-app-client-secret

# --- Discord room announcements (optional) --------------------------
# When set, the server posts a LIVE-updating message to a Discord channel
# every time a PUBLIC lobby is created (room name, mod, player count, host,
# status). The message is edited in place as players join/leave and the match
# starts, and edited to "Closed" when the room ends. Private rooms are not
# announced. Leave it blank to turn the feature off — the service starts and
# runs fine without it.
#
# To get a webhook URL: in Discord, open the target channel's settings →
# Integrations → Webhooks → New Webhook → Copy Webhook URL. It looks like:
#   https://discord.com/api/webhooks/<id>/<token>
# Keep it secret: anyone with this URL can post to the channel.
#
# MULTIPLE channels / servers: separate several webhook URLs with commas. The
# announcement is posted and kept in sync in every one of them:
#   DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/AAA/aaa,https://discord.com/api/webhooks/BBB/bbb
DISCORD_WEBHOOK_URL=
