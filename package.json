{
  "name": "wol-launcher-lobby-node",
  "version": "0.1.0",
  "private": true,
  "description": "Self-hosted Node.js backend for the AoE3 Mod Launcher multiplayer lobby. Migrated from the original Cloudflare Worker so the launcher can run against a single VM instead of relying on the Workers + D1 + KV + R2 quartet.",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "migrate": "tsx src/cli/migrate.ts"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/websocket": "^10.0.1",
    "better-sqlite3": "^11.3.0",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "glicko2": "^1.2.1",
    "undici": "^6.20.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.7.4",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
